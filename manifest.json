{
    "manifest_version": 2.0,
    "id": "massz",
    "name": "MASSZ",
    "version": "2.0.0",
    "namespace": "MASSZ",
    "author": "Leandro Dethloff",
    "description": "Módulo para Abrir Seus Sistemas no Zabbix | Module to Open Your Systems in Zabbix",
    "actions": {
        "massz.manage": {
            "class": "CControllerMasszManage",
            "view": "massz.manage"
        },
        "massz.save": {
            "class": "CControllerMasszSave",
            "layout": "layout.json"
        }
    },
    "assets": {
        "css": [
            "massz.css",
            "massz-dark.css"
        ],
        "js": [
            "massz.utils.js"
        ]
    }
}
